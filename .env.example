# Runtime
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
# Comma-separated list of allowed browser origins. Leave unset to allow all
# (safe here since auth is a stateless bearer token, not cookies). Set an
# allowlist in production, e.g. CORS_ORIGINS=https://app.example.com
# CORS_ORIGINS=

# Database (MySQL)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=demo_credit
# A full connection string, if provided, overrides the discrete DB_* vars above.
# DATABASE_URL=mysql://user:password@host:3306/demo_credit
# Set to true when connecting to a managed MySQL host that requires TLS.
DB_SSL=false
# When DB_SSL=true, verify the server certificate. Keep true in production.
DB_SSL_REJECT_UNAUTHORIZED=true
# Base64-encoded CA certificate (PEM) to pin a managed database's CA (e.g. Aiven).
# DB_CA_CERT=

# Auth (faux token)
# Use a long, random value in every real environment.
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=1h

# Lendsqr Adjutor (Karma blacklist)
ADJUTOR_BASE_URL=https://adjutor.lendsqr.com/v2
ADJUTOR_API_KEY=your-adjutor-api-key
